# MyKavaBar Backend Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mykavabar

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Optional: Cloud storage (for photos)
# R2_BUCKET_URL=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
